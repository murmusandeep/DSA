4. Print Arrays in 3(Three) Different ways.
            System.out.println("Enter a values");

            Scanner sc = new Scanner(System.in);

            int[] arr = new int[5];

            for(int i = 0; i < arr.length; i++){
                arr[i] = sc.nextInt();
            }

            a) System.out.print(Arrays.toString(arr) + " ");

            System.out.println();

            b) for(int a : arr)
               {
                    System.out.print(a + " ");
               }

            System.out.println();

            c) for(int i = 0; i < arr.length; i++)
                {
                    System.out.print(arr[i] + " ");
                }
